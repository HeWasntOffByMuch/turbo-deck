up" viewBox="0 0 24 24"><polygon points="2 18 12 6 22 18" /></svg></a> <a title="Vote down" data-register_action="community_vote" class="vote_down_btn vote_btn" href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fpixeldudesmaker&amp;intent=community"><svg height="20" width="20" version="1.1" aria-hidden role="img" class="svgicon icon_vote_down" viewBox="0 0 24 24"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/0x72"><div class="post_avatar" style="background-image: url(https://img.itch.zone/aW1nLzE5NzEwNTEucG5n/25x25%23/rllnE7.png)"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/0x72">0x72</a></span><span title="2023-07-08 20:51:51" class="post_date"><a href="https://itch.io/post/8072123">2 years ago</a></span> <span class="edit_message">(1 edit)</span> <span class="vote_counts"></span></div><div class="post_content"><div class="post_body user_formatted" dir="auto"><p>Hi there!<br><br>It&#x27;s all undocumented but you should be able to just enlarge the files and it should work.</p>
